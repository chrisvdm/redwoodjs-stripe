{
  "name": "redwoodjs-stripe",
  "version": "0.0.1",
  "description": "A Redwood/Stripe integration made easy",
  "main": "./dist/cjs/api/index.js",
  "targets": {
    "api-cjs": {
      "source": "src/api/index.js",
      "isLibrary": true,
      "context": "node",
      "outputFormat": "commonjs"
    },
    "web-cjs": {
      "source": "src/web/index.js",
      "isLibrary": true,
      "context": "browser",
      "outputFormat": "commonjs",
      "includeNodeModules": [
        "@stripe/stripe-js"
      ]
    },
    "cli": {
      "source": "cli/index.js",
      "isLibrary": true,
      "context": "node",
      "outputFormat": "commonjs"
    }
  },
  "scripts": {
    "watch": "parcel watch",
    "build": "parcel build",
    "test": "echo \"Error: no test specified\" && exit 1",
    "stripe": "node ./cli/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chrisvdm/redwoodjs-stripe.git"
  },
  "keywords": [
    "redwood",
    "stripe"
  ],
  "author": "Chrisvdm",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/chrisvdm/redwoodjs-stripe/issues"
  },
  "homepage": "https://github.com/chrisvdm/redwoodjs-stripe#readme",
  "devDependencies": {
    "@babel/runtime-corejs3": "^7.17.9",
    "@parcel/transformer-graphql": "latest",
    "core-js": "^3.22.5",
    "graphql-tag": "2.x",
    "parcel": "latest"
  },
  "dependencies": {
    "@snaplet/copycat": "^0.3.0",
    "@stripe/stripe-js": "1.29.0",
    "stripe": "^8.220.0",
    "yargs": "^17.5.1"
  },
  "peerDependencies": {
    "@redwoodjs/core": "1.x",
    "@redwoodjs/web": "1.x",
    "graphql-tag": "2.x",
    "react": "17.0.2",
    "react-dom": "17.0.2"
  }
}
